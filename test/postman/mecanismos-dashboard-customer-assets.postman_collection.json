        {
          "name": "Login as Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const now = Date.now().toString();",
                  "const random = Math.floor(Math.random() * 1000).toString().padStart(3, '0');",
                  "const runId = `${now.slice(-6)}${random}`;",
                  "const plate = `PM${runId.slice(-5)}`;",
                  "pm.collectionVariables.set('runId', runId);",
                   "pm.collectionVariables.set('customerId', '');",
                   "pm.collectionVariables.set('vehicleId', '');",
                   "pm.collectionVariables.set('componentId', '');",
                   "pm.collectionVariables.set('componentTypeId', '');",
                   "pm.collectionVariables.set('customerName', `Postman Runner ${runId}`);",
                  "pm.collectionVariables.set('customerDocumentNumber', `9${runId.slice(0, 8)}`);",
                  "pm.collectionVariables.set('customerEmail', `runner.${runId}@mecanismos.test`);",
                  "pm.collectionVariables.set('customerSearch', runId);",
                  "pm.collectionVariables.set('vehiclePlate', plate);",
                   "pm.collectionVariables.set('vehicleSearch', plate);",
                   "pm.collectionVariables.set('componentIdentifier', `PM-COMP-${runId}`);",
                   "pm.collectionVariables.set('componentSearch', `PM-COMP-${runId}`);",
                   "pm.collectionVariables.set('componentTypeName', `Postman Tipo ${runId}`);",
                   "pm.collectionVariables.set('componentTypeSearch', runId);"
                 ]
               }
             },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin login returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const setCookies = pm.response.headers.all().filter((header) => header.key.toLowerCase() === 'set-cookie');",
                  "pm.test('admin login returns sanitized admin payload', function () {",
                  "  pm.expect(body.email).to.eql(pm.collectionVariables.get('adminEmail'));",
                  "  pm.expect(body.role).to.eql('ADMIN');",
                  "  pm.expect(body.accessToken).to.eql(undefined);",
                  "  pm.expect(body.refreshToken).to.eql(undefined);",
                  "});",
                  "pm.test('admin login issues access and refresh cookies', function () {",
                  "  pm.expect(setCookies.some((header) => header.value.includes('md_access='))).to.eql(true);",
                  "  pm.expect(setCookies.some((header) => header.value.includes('md_refresh='))).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
