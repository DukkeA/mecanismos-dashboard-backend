{
  "info": {
    "name": "Mecanismos Dashboard Suppliers",
    "_postman_id": "62e4a0b4-0cca-48bd-bb12-28f9547f2db8",
    "description": "Runner-ready supplemental verification for supplier create/list/get/update, duplicate-name acceptance, multi-phone normalization, and protected-route error cases.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "adminEmail", "value": "admin@mecanismos.test" },
    { "key": "adminPassword", "value": "Admin123!" },
    { "key": "mechanicEmail", "value": "mecanico@mecanismos.test" },
    { "key": "mechanicPassword", "value": "Mecanico123!" },
    { "key": "runId", "value": "" },
    { "key": "supplierId", "value": "" },
    { "key": "supplierName", "value": "" },
    { "key": "supplierSearch", "value": "" },
    { "key": "supplierDocumentNumber", "value": "" },
    { "key": "supplierEmail", "value": "" },
    { "key": "missingSupplierId", "value": "" }
  ],
  "item": [
    {
      "name": "Runner Happy Path",
      "item": [
        {
          "name": "Login as Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const now = Date.now().toString();",
                  "const random = Math.floor(Math.random() * 1000).toString().padStart(3, '0');",
                  "const runId = `${now.slice(-6)}${random}`;",
                  "pm.collectionVariables.set('runId', runId);",
                  "pm.collectionVariables.set('supplierId', '');",
                  "pm.collectionVariables.set('supplierName', `Proveedor Runner ${runId}`);",
                  "pm.collectionVariables.set('supplierSearch', runId);",
                  "pm.collectionVariables.set('supplierDocumentNumber', `9${runId.slice(0, 8)}`);",
                  "pm.collectionVariables.set('supplierEmail', `supplier.${runId}@mecanismos.test`);",
                  "pm.collectionVariables.set('missingSupplierId', `missing-${runId}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin login returns 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('admin login returns admin payload', function () {",
                  "  pm.expect(body.email).to.eql(pm.collectionVariables.get('adminEmail'));",
                  "  pm.expect(body.role).to.eql('ADMIN');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Supplier",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{supplierName}}\",\n  \"type\": \"COMPANY\",\n  \"documentType\": \"NIT\",\n  \"documentNumber\": \"{{supplierDocumentNumber}}\",\n  \"email\": \"{{supplierEmail}}\",\n  \"contactName\": \"Laura Runner\",\n  \"phones\": [\n    {\n      \"label\": \"Principal\",\n      \"phone\": \"3001234567\",\n      \"isPrimary\": false,\n      \"hasWhatsapp\": true\n    },\n    {\n      \"label\": \"Bodega\",\n      \"phone\": \"3109876543\",\n      \"isPrimary\": false,\n      \"hasWhatsapp\": false\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/suppliers",
              "host": ["{{baseUrl}}"],
              "path": ["suppliers"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('create supplier returns 201', function () { pm.response.to.have.status(201); });",
                "const body = pm.response.json();",
                "pm.collectionVariables.set('supplierId', body.id);",
                "pm.test('create supplier captures supplierId', function () {",
                "  pm.expect(body.id).to.be.a('string');",
                "  pm.expect(pm.collectionVariables.get('supplierId')).to.eql(body.id);",
                "});",
                "pm.test('create supplier normalizes first phone as primary', function () {",
                "  pm.expect(body.phones[0].isPrimary).to.eql(true);",
                "  pm.expect(body.phones[0].hasWhatsapp).to.eql(true);",
                "  pm.expect(body.phones[1].isPrimary).to.eql(false);",
                "});"
              ]
            }
          }]
        },
        {
          "name": "Create Duplicate Supplier Name",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{supplierName}}\",\n  \"type\": \"COMPANY\",\n  \"documentType\": \"NIT\",\n  \"documentNumber\": \"8{{supplierDocumentNumber}}\",\n  \"email\": \"duplicate.{{runId}}@mecanismos.test\",\n  \"phones\": [\n    {\n      \"phone\": \"3010000000\",\n      \"isPrimary\": true,\n      \"hasWhatsapp\": false\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/suppliers",
              "host": ["{{baseUrl}}"],
              "path": ["suppliers"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('duplicate supplier name still returns 201', function () { pm.response.to.have.status(201); });",
                "const body = pm.response.json();",
                "pm.test('duplicate supplier name is accepted', function () {",
                "  pm.expect(body.name).to.eql(pm.collectionVariables.get('supplierName'));",
                "  pm.expect(body.id).to.not.eql(pm.collectionVariables.get('supplierId'));",
                "});"
              ]
            }
          }]
        },
        {
          "name": "List Suppliers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/suppliers?page=1&limit=10&search={{supplierSearch}}",
              "host": ["{{baseUrl}}"],
              "path": ["suppliers"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "{{supplierSearch}}" }
              ]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('list suppliers returns 200', function () { pm.response.to.have.status(200); });",
                "const body = pm.response.json();",
                "pm.test('list suppliers includes created supplier', function () {",
                "  const supplierId = pm.collectionVariables.get('supplierId');",
                "  pm.expect(body.data.some((item) => item.id === supplierId)).to.eql(true);",
                "});"
              ]
            }
          }]
        },
        {
          "name": "Get Supplier",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/suppliers/{{supplierId}}",
              "host": ["{{baseUrl}}"],
              "path": ["suppliers", "{{supplierId}}"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('get supplier returns 200', function () { pm.response.to.have.status(200); });",
                "const body = pm.response.json();",
                "pm.test('get supplier uses captured supplierId', function () {",
                "  pm.expect(body.id).to.eql(pm.collectionVariables.get('supplierId'));",
                "});"
              ]
            }
          }]
        },
        {
          "name": "Update Supplier",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contactName\": \"Andrea Runner\",\n  \"phones\": [\n    {\n      \"label\": \"Principal\",\n      \"phone\": \"3009998888\",\n      \"isPrimary\": false,\n      \"hasWhatsapp\": true\n    },\n    {\n      \"label\": \"Bodega\",\n      \"phone\": \"3107776666\",\n      \"isPrimary\": false,\n      \"hasWhatsapp\": false\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/suppliers/{{supplierId}}",
              "host": ["{{baseUrl}}"],
              "path": ["suppliers", "{{supplierId}}"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('update supplier returns 200', function () { pm.response.to.have.status(200); });",
                "const body = pm.response.json();",
                "pm.test('update supplier preserves a single primary phone', function () {",
                "  pm.expect(body.phones[0].isPrimary).to.eql(true);",
                "  pm.expect(body.phones[1].isPrimary).to.eql(false);",
                "});"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "Protection & Error Checks",
      "item": [
        {
          "name": "Create Supplier invalid payload",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"   \",\n  \"type\": \"COMPANY\",\n  \"phones\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/suppliers",
              "host": ["{{baseUrl}}"],
              "path": ["suppliers"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('invalid create returns 400', function () { pm.response.to.have.status(400); });"
              ]
            }
          }]
        },
        {
          "name": "Logout Admin Session",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('logout returns 200', function () { pm.response.to.have.status(200); });"
              ]
            }
          }]
        },
        {
          "name": "Supplier List after Logout returns 401",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/suppliers",
              "host": ["{{baseUrl}}"],
              "path": ["suppliers"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('supplier list is unauthorized after logout', function () { pm.response.to.have.status(401); });"
              ]
            }
          }]
        },
        {
          "name": "Login as Mechanic",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{mechanicEmail}}\",\n  \"password\": \"{{mechanicPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('mechanic login returns 200', function () { pm.response.to.have.status(200); });"
              ]
            }
          }]
        },
        {
          "name": "Supplier List forbidden for Mechanic",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/suppliers",
              "host": ["{{baseUrl}}"],
              "path": ["suppliers"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('mechanic supplier list returns 403', function () { pm.response.to.have.status(403); });"
              ]
            }
          }]
        }
      ]
    }
  ]
}
