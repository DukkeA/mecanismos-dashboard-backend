{
  "info": {
    "name": "Mecanismos Dashboard Overview",
    "_postman_id": "74e4787d-73e2-4c0c-a6ca-0b0d2b51f510",
    "description": "Reviewer path for GET /dashboard/overview with flexible from/to ranges, approximation notes, and role protection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "adminEmail", "value": "admin@mecanismos.test" },
    { "key": "adminPassword", "value": "Admin123!" },
    { "key": "mechanicEmail", "value": "mecanico@mecanismos.test" },
    { "key": "mechanicPassword", "value": "Mecanico123!" }
  ],
  "item": [
    {
      "name": "Happy Path",
      "item": [
        {
          "name": "Login as Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Dashboard Overview",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/dashboard/overview?from=2026-04-01T00:00:00.000Z&to=2026-05-31T23:59:59.999Z",
              "host": ["{{baseUrl}}"],
              "path": ["dashboard", "overview"],
              "query": [
                { "key": "from", "value": "2026-04-01T00:00:00.000Z" },
                { "key": "to", "value": "2026-05-31T23:59:59.999Z" }
              ]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('overview returns 200', function () { pm.response.to.have.status(200); });",
                "const body = pm.response.json();",
                "pm.test('overview includes KPI and progress sections', function () {",
                "  pm.expect(body.kpis).to.be.an('object');",
                "  pm.expect(body.progress).to.be.an('object');",
                "  pm.expect(body.alerts.previews.pendingReceivables.length).to.be.below(4);",
                "});",
                "pm.test('overview preserves approximation semantics', function () {",
                "  pm.expect(body.metadata.approximate).to.eql(true);",
                "  pm.expect(body.metadata.notes.some((note) => note.includes('approximate'))).to.eql(true);",
                "});"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "Protection & Validation",
      "item": [
        {
          "name": "Reject Reversed Range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/dashboard/overview?from=2026-05-31T00:00:00.000Z&to=2026-05-01T00:00:00.000Z",
              "host": ["{{baseUrl}}"],
              "path": ["dashboard", "overview"],
              "query": [
                { "key": "from", "value": "2026-05-31T00:00:00.000Z" },
                { "key": "to", "value": "2026-05-01T00:00:00.000Z" }
              ]
            }
          }
        },
        {
          "name": "Login as Mechanic",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{mechanicEmail}}\",\n  \"password\": \"{{mechanicPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Mechanic Forbidden Overview",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/dashboard/overview",
              "host": ["{{baseUrl}}"],
              "path": ["dashboard", "overview"]
            }
          }
        }
      ]
    }
  ]
}
