  "item": [
    {
      "name": "Admin Runner Happy Path",
      "item": [
        {
          "name": "Login as Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const setCookies = pm.response.headers.all().filter((header) => header.key.toLowerCase() === 'set-cookie');",
                  "pm.test('login returns sanitized admin user', function () {",
                  "  pm.expect(body.id).to.be.a('string');",
                  "  pm.expect(body.email).to.eql(pm.collectionVariables.get('adminEmail'));",
                  "  pm.expect(body.role).to.eql('ADMIN');",
                  "  pm.expect(body.accessToken).to.eql(undefined);",
                  "  pm.expect(body.refreshToken).to.eql(undefined);",
                  "  pm.expect(body.passwordHash).to.eql(undefined);",
                  "});",
                  "pm.test('login issues access and refresh cookies', function () {",
                  "  pm.expect(setCookies.some((header) => header.value.includes('md_access='))).to.eql(true);",
                  "  pm.expect(setCookies.some((header) => header.value.includes('md_refresh='))).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
