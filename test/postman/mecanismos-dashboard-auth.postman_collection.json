                  "  pm.expect(body.data.some((user) => user.id === pm.collectionVariables.get('managedUserId'))).to.eql(true);",
                  "  pm.expect(JSON.stringify(body)).to.not.include('passwordHash');",
                  "});"
                ]
              }
            }
          ]
        },
