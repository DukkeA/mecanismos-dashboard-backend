      "item": [
        {
          "name": "Admin Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{managedUserEmail}}\",\n  \"name\": \"Postman Managed User\",\n  \"role\": \"SALES\",\n  \"temporaryPassword\": \"{{managedUserTemporaryPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "users"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin create user returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('managedUserId', body.id);",
                  "pm.test('admin create user returns one-time temporary password', function () {",
                  "  pm.expect(body.id).to.be.a('string');",
                  "  pm.expect(body.email).to.eql(pm.collectionVariables.get('managedUserEmail'));",
                  "  pm.expect(body.mustChangePassword).to.eql(true);",
                  "  pm.expect(body.temporaryPassword).to.eql(pm.collectionVariables.get('managedUserTemporaryPassword'));",
                  "  pm.expect(body.passwordHash).to.eql(undefined);",
                  "});"
                ]
              }
            }
          ]
        },
