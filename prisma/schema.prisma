generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model AppSettings {
  id                       Int      @id @default(1)
  companyName              String   @default("Mecanismos Tecnicos")
  currencyCode             String   @default("COP")
  monthlyWorkingHours      Int      @default(176)
  defaultLaborHourlyRate   Int      @default(50000)
  saleContingencyPct       Int      @default(5)
  workshopContingencyPct   Int      @default(10)
  diagnosticContingencyPct Int      @default(20)
  minimumMarkupPct         Int      @default(20)
  recommendedMarkupPct     Int      @default(35)
  highMarkupPct            Int      @default(50)
  createdAt                DateTime @default(now())
  updatedAt                DateTime
  auditHistory             AppSettingsAuditHistory[]
}

model AppSettingsAuditHistory {
  id            String   @id
  appSettingsId Int      @default(1)
  actorUserId   String
  changedFields String[]
  beforeValues  Json
  afterValues   Json
  createdAt     DateTime @default(now())
  appSettings   AppSettings @relation(fields: [appSettingsId], references: [id], onDelete: Restrict)

  @@index([appSettingsId, createdAt])
  @@index([actorUserId, createdAt])
}

model Component {
  id              String        @id
  customerId      String
  vehicleId       String?
  componentTypeId String
  brand           String
  reference       String
  identifier      String?
  notes           Json?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  Customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  componentType   ComponentType @relation(fields: [componentTypeId], references: [id])
  Vehicle         Vehicle?      @relation(fields: [vehicleId], references: [id])
  WorkOrder       WorkOrder[]

  @@index([componentTypeId])
  @@index([componentTypeId, isActive])
  @@index([customerId])
  @@index([customerId, isActive])
  @@index([identifier])
  @@index([isActive])
  @@index([vehicleId])
  @@index([vehicleId, isActive])
}

model ComponentType {
  id          String      @id
  name        String
  slug        String      @unique
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  components  Component[]

  @@index([isActive])
  @@index([name])
}

model CostCenter {
  id        String     @id
  code      String     @unique
  name      String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime
  Employee  Employee[]
  EmployeeMonthlyPayrollLine EmployeeMonthlyPayrollLine[]
  Expense   Expense[]
}

model Customer {
  id             String               @id
  name           String
  phone          String
  documentType   CustomerDocumentType
  documentNumber String
  email          String?
  notes          Json?
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime
  Component      Component[]
  Vehicle        Vehicle[]
  WorkOrder      WorkOrder[]

  @@unique([documentType, documentNumber])
  @@index([documentType, isActive])
  @@index([isActive])
}

model Employee {
  id                String          @id
  name              String
  type              EmployeeType
  phone             String?
  baseSalaryMonthly Int             @default(0)
  costCenterId      String?
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime
  CostCenter        CostCenter?     @relation(fields: [costCenterId], references: [id])
  EmployeeBonus     EmployeeBonus[]
  EmployeeMonthlyPayrollLine EmployeeMonthlyPayrollLine[]
  WorkOrder         WorkOrder[]

  @@index([costCenterId])
  @@index([type])
}

model EmployeeBonus {
  id            String         @id
  employeeId    String
  amount        Int
  description   String?
  paidAt        DateTime
  paymentMethod PaymentMethod?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  Employee      Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([paidAt])
}

model EmployeeMonthlyPayroll {
  id           String                       @id
  year         Int
  month        Int
  status       EmployeeMonthlyPayrollStatus @default(DRAFT)
  salaryTotal  Int                         @default(0)
  bonusTotal   Int                         @default(0)
  grandTotal   Int                         @default(0)
  generatedAt  DateTime
  finalizedAt  DateTime?
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime
  lines        EmployeeMonthlyPayrollLine[]

  @@unique([year, month], name: "year_month")
  @@index([status, year, month])
  @@index([generatedAt])
}

model EmployeeMonthlyPayrollLine {
  id                        String                 @id
  payrollId                 String
  employeeId                String?
  employeeName              String
  employeeType              EmployeeType
  costCenterId              String?
  costCenterCode            String?
  costCenterName            String?
  baseSalaryMonthlySnapshot Int
  bonusTotal                Int                    @default(0)
  bonusCount                Int                    @default(0)
  totalPay                  Int
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime
  payroll                   EmployeeMonthlyPayroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employee                  Employee?              @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  costCenter                CostCenter?            @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  @@index([payrollId])
  @@index([employeeId])
  @@index([costCenterId])
}

model Expense {
  id            String          @id
  name          String
  category      ExpenseCategory
  amount        Int
  costCenterId  String?
  expectedAt    DateTime
  paidAt        DateTime?
  paymentMethod PaymentMethod?
  notes         Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  CostCenter    CostCenter?     @relation(fields: [costCenterId], references: [id])

  @@index([costCenterId])
  @@index([expectedAt])
  @@index([paidAt])
}

model InventoryItem {
  id                    String                  @id
  name                  String
  itemType              InventoryItemType
  condition             InventoryCondition      @default(NEW)
  brand                 String?
  reference             String?
  identifier            String?
  notes                 Json?
  minimumStock          Int                     @default(0)
  defaultSalePrice      Int?
  isActive              Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  InventoryMovement     InventoryMovement[]
  SupplierQuoteHistory  SupplierQuoteHistory[]
  WorkOrderActualCost   WorkOrderActualCost[]
  WorkOrderEstimateLine WorkOrderEstimateLine[]

  @@index([identifier])
  @@index([isActive])
  @@index([itemType])
  @@index([condition])
  @@index([name])
  @@index([reference])
}

model InventoryMovement {
  id                     String                  @id
  inventoryItemId        String
  movementType           InventoryMovementType
  reason                 InventoryMovementReason
  quantity               Int
  unitCost               Int?
  supplierId             String?
  workOrderId            String?
  isReservedForWorkOrder Boolean                 @default(false)
  occurredAt             DateTime
  notes                  Json?
  createdAt              DateTime                @default(now())
  InventoryItem          InventoryItem           @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  Supplier               Supplier?               @relation(fields: [supplierId], references: [id])
  WorkOrder              WorkOrder?              @relation(fields: [workOrderId], references: [id])

  @@index([inventoryItemId, occurredAt])
  @@index([supplierId])
  @@index([workOrderId, occurredAt])
}

model ServiceCatalog {
  id                    String                  @id
  name                  String
  slug                  String                  @unique
  description           String?
  isActive              Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  WorkOrderEstimateLine WorkOrderEstimateLine[]

  @@index([isActive])
  @@index([name])
}

model Supplier {
  id                    String                  @id
  name                  String
  type                  SupplierType            @default(COMPANY)
  contactName           String?
  documentType          SupplierDocumentType?
  documentNumber        String?
  email                 String?
  notes                 Json?
  isActive              Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  InventoryMovement     InventoryMovement[]
  phones                SupplierPhone[]
  SupplierQuoteHistory  SupplierQuoteHistory[]
  WorkOrderActualCost   WorkOrderActualCost[]
  WorkOrderEstimateLine WorkOrderEstimateLine[]

  @@index([documentNumber])
  @@index([isActive])
  @@index([name])
  @@index([type])
}

model SupplierPhone {
  id          String   @id
  supplierId  String
  label       String?
  phone       String
  isPrimary   Boolean  @default(false)
  hasWhatsapp Boolean  @default(false)
  notes       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([isPrimary])
  @@index([phone])
  @@index([supplierId])
}

model SupplierQuoteHistory {
  id                        String                  @id
  supplierId                String
  inventoryItemId           String
  workOrderId               String?
  quotedCost                Int
  notes                     Json?
  quotedAt                  DateTime
  status                    SupplierQuoteStatus     @default(ACTIVE)
  correctionReason          String?
  voidReason                String?
  voidedAt                  DateTime?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime
  InventoryItem             InventoryItem           @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  Supplier                  Supplier                @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  WorkOrder                 WorkOrder?              @relation(fields: [workOrderId], references: [id])
  WorkOrderActualCostLink   WorkOrderActualCost[]   @relation("WorkOrderActualCostSupplierQuoteHistory")
  WorkOrderEstimateLineLink WorkOrderEstimateLine[] @relation("WorkOrderEstimateLineSupplierQuoteHistory")

  @@index([inventoryItemId, quotedAt])
  @@index([inventoryItemId, status, quotedAt])
  @@index([supplierId, quotedAt])
  @@index([supplierId, status, quotedAt])
  @@index([status])
  @@index([workOrderId])
}

model Vehicle {
  id             String      @id
  customerId     String
  brand          String
  modelReference String
  plate          String      @unique
  notes          Json?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime
  Component      Component[]
  Customer       Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  WorkOrder      WorkOrder[]

  @@index([customerId])
  @@index([customerId, isActive])
  @@index([isActive])
}

model WorkOrder {
  id                       String                    @id
  number                   Int                       @unique @default(autoincrement())
  type                     WorkOrderType
  status                   WorkOrderStatus           @default(IN_PROGRESS)
  paymentStatus            PaymentStatus             @default(PENDING)
  customerId               String
  vehicleId                String?
  componentId              String?
  assignedEmployeeId       String?
  summary                  String
  externalLink             String?
  notes                    Json?
  estimatedCompletionAt    DateTime?
  estimatedCollectionAt    DateTime?
  completedAt              DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime
  InventoryMovement        InventoryMovement[]
  SupplierQuoteHistory     SupplierQuoteHistory[]
  Employee                 Employee?                 @relation(fields: [assignedEmployeeId], references: [id])
  Component                Component?                @relation(fields: [componentId], references: [id])
  Customer                 Customer                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  Vehicle                  Vehicle?                  @relation(fields: [vehicleId], references: [id])
  WorkOrderActualCost      WorkOrderActualCost[]
  WorkOrderEstimate        WorkOrderEstimate[]
  WorkOrderPayment         WorkOrderPayment[]
  WorkshopWorkOrderDetails WorkshopWorkOrderDetails?

  @@index([assignedEmployeeId])
  @@index([completedAt])
  @@index([customerId])
  @@index([estimatedCollectionAt])
  @@index([paymentStatus])
  @@index([status])
}

model WorkOrderActualCost {
  id                     String                @id
  workOrderId            String
  category               WorkOrderCostCategory
  description            String
  amount                 Int
  supplierId             String?
  inventoryItemId        String?
  supplierQuoteHistoryId String?
  paymentMethod          PaymentMethod?
  incurredAt             DateTime
  notes                  Json?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime
  InventoryItem          InventoryItem?        @relation(fields: [inventoryItemId], references: [id])
  SupplierQuoteHistory   SupplierQuoteHistory? @relation("WorkOrderActualCostSupplierQuoteHistory", fields: [supplierQuoteHistoryId], references: [id])
  Supplier               Supplier?             @relation(fields: [supplierId], references: [id])
  WorkOrder              WorkOrder             @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([incurredAt])
  @@index([inventoryItemId])
  @@index([supplierQuoteHistoryId])
  @@index([supplierId])
  @@index([workOrderId])
}

model WorkOrderEstimate {
  id                      String                  @id
  workOrderId             String
  phase                   EstimatePhase
  estimatedLaborHours     Decimal?                @db.Decimal(6, 2)
  laborHourlyCostSnapshot Int?
  baseCostAmount          Int                     @default(0)
  contingencyPct          Int?
  contingencyAmount       Int                     @default(0)
  totalCostAmount         Int                     @default(0)
  totalPriceAmount        Int                     @default(0)
  recommendedMinimumPrice Int?
  recommendedPrice        Int?
  recommendedHighPrice    Int?
  notes                   Json?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime
  WorkOrder               WorkOrder               @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  WorkOrderEstimateLine   WorkOrderEstimateLine[]

  @@unique([workOrderId, phase])
  @@index([phase])
}

model WorkOrderEstimateLine {
  id                     String                @id
  estimateId             String
  lineType               EstimateLineType
  description            String
  inventoryItemId        String?
  serviceCatalogId       String?
  supplierId             String?
  supplierQuoteHistoryId String?
  quantity               Int                   @default(1)
  unitCost               Int?
  unitPrice              Int?
  notes                  Json?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime
  WorkOrderEstimate      WorkOrderEstimate     @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  InventoryItem          InventoryItem?        @relation(fields: [inventoryItemId], references: [id])
  ServiceCatalog         ServiceCatalog?       @relation(fields: [serviceCatalogId], references: [id])
  SupplierQuoteHistory   SupplierQuoteHistory? @relation("WorkOrderEstimateLineSupplierQuoteHistory", fields: [supplierQuoteHistoryId], references: [id])
  Supplier               Supplier?             @relation(fields: [supplierId], references: [id])

  @@index([estimateId])
  @@index([inventoryItemId])
  @@index([serviceCatalogId])
  @@index([supplierQuoteHistoryId])
  @@index([supplierId])
}

model WorkOrderPayment {
  id            String         @id
  workOrderId   String
  amount        Int
  paymentMethod PaymentMethod?
  paidAt        DateTime
  notes         Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  WorkOrder     WorkOrder      @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([paidAt])
  @@index([workOrderId])
}

model WorkshopWorkOrderDetails {
  id                    String    @id
  workOrderId           String    @unique
  customerReportedIssue String?
  diagnosisRequired     Boolean   @default(false)
  diagnosisSummary      String?
  WorkOrder             WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

model account {
  id                        String    @id
  userId                    String    @unique
  passwordHash              String
  passwordUpdatedAt         DateTime?
  recoveryPhraseHash        String?
  recoveryPhraseGeneratedAt DateTime?
  recoveryPhraseConsumedAt  DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime
  user                      user      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model session {
  id                  String    @id
  expiresAt           DateTime
  tokenDigest         String    @unique
  createdAt           DateTime  @default(now())
  updatedAt           DateTime
  revokedAt           DateTime?
  replacedBySessionId String?   @unique
  familyId            String
  lastUsedAt          DateTime?
  ipAddress           String?
  userAgent           String?
  userId              String
  replacedBySession   session?  @relation("SessionReplacement", fields: [replacedBySessionId], references: [id])
  previousSession     session?  @relation("SessionReplacement")
  user                user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([userId])
}

model user {
  id                 String    @id
  name               String
  email              String    @unique
  role               UserRole  @default(ADMIN)
  isActive           Boolean   @default(true)
  authVersion        Int       @default(0)
  mustChangePassword Boolean   @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime
  account            account?
  session            session[]
}

enum UserRole {
  ADMIN
  SALES
  MECHANIC
}

enum CustomerDocumentType {
  CEDULA
  NIT
}

enum SupplierDocumentType {
  CEDULA
  NIT
  OTHER
}

enum SupplierType {
  PERSON
  COMPANY
}

enum EmployeeType {
  MECHANIC
  SALES
  ADMIN
}

enum EmployeeMonthlyPayrollStatus {
  DRAFT
  FINALIZED
}

enum EstimateLineType {
  PART
  SERVICE
  OTHER
}

enum EstimatePhase {
  INITIAL
  FINAL
}

enum ExpenseCategory {
  RENT
  UTILITY
  OTHER
}

enum InventoryCondition {
  NEW
  USED
  REMANUFACTURED
}

enum InventoryItemType {
  STOCK_OWNED
  DEMAND_PURCHASED
  REPLACEMENT_PART
  OWNED_COMPONENT
  OTHER
}

enum SupplierQuoteStatus {
  ACTIVE
  VOIDED
}

enum InventoryMovementReason {
  PURCHASE
  WORK_ORDER_PURCHASE
  WORK_ORDER_CONSUMPTION
  MANUAL_ADJUSTMENT
  RETURN
  SALE
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  OTHER
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum WorkOrderCostCategory {
  OUTSOURCED_SERVICE
  DIRECT_PURCHASE
  MISC
  OTHER
}

enum WorkOrderStatus {
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

enum WorkOrderType {
  SALE
  WORKSHOP
}
