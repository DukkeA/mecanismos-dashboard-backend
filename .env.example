# Local runtime + Prisma CLI
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/mecanismos_dashboard"
PORT=3000

# Auth secrets
AUTH_ACCESS_TOKEN_SECRET="replace-with-long-random-access-secret"
AUTH_REFRESH_TOKEN_SECRET="replace-with-long-random-refresh-secret"

# Auth CORS + TTLs
AUTH_ALLOWED_ORIGINS="http://localhost:5173"
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=1209600

# Auth cookie policy
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_ACCESS_NAME=md_access
AUTH_COOKIE_ACCESS_PATH=/
AUTH_COOKIE_REFRESH_NAME=md_refresh
AUTH_COOKIE_REFRESH_PATH=/auth/refresh
